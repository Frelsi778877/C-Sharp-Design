<Window x:Class="SudokuUnlimited.LoadGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SudokuUnlimited"
        mc:Ignorable="d"
        Title="LoadGame" WindowStyle="None" ResizeMode="NoResize" WindowState="Maximized">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#175676" Offset="0.0"/>
            <GradientStop Color="#4BA3C3" Offset="0.5"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <StackPanel Margin="50" HorizontalAlignment="Center" x:Name="CollectionsPanel" Visibility="Visible">
            <TextBlock Text="Collections"
               FontSize="68"
               FontWeight="Bold"
               Foreground="White"
               Margin="0,0,0,15"/>

            <ListView x:Name="CollectionsTable"
              MouseDoubleClick="CollectionsTable_DoubleClick"
              Background="White"
              BorderBrush="#4BA3C3"
              FontSize="30"
              BorderThickness="2">
                <ListView.Resources>
                    <Style TargetType="GridViewColumnHeader">
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="48"/>
                        <Setter Property="Foreground" Value="#175676"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    </Style>
                </ListView.Resources>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name"
                                Width="400"
                                DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Difficulty"
                                Width="320"
                                DisplayMemberBinding="{Binding Difficulty}"/>
                        
                        <GridViewColumn Header="Puzzles"
                                Width="300"
                                DisplayMemberBinding="{Binding PuzzleCount}"/>  
                        <GridViewColumn Header="Solved"
                                Width="300"
                                DisplayMemberBinding="{Binding SolvedCount}"/>
                    </GridView>
                </ListView.View>
            </ListView>
            <Button x:Name="ImportButton"
        Click="ImportButton_Click"
        HorizontalAlignment="Left"
        Margin="0,15,0,0"
        Width="140"
        Height="40"
        Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                    Background="White"
                    BorderBrush="#4BA3C3"
                    BorderThickness="2"
                    CornerRadius="6">
                            <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                                <Path x:Name="Icon"
                          Data="M0,2 C0,0.9 0.9,0 2,0 L6,0 L8,2 L14,2 C15.1,2 16,2.9 16,4 L16,12 C16,13.1 15.1,14 14,14 L2,14 C0.9,14 0,13.1 0,12 Z"
                          Fill="#4BA3C3"
                          Stretch="Uniform"
                          Width="22"
                          Height="22"
                          Margin="0,0,8,0"/>
                                <TextBlock x:Name="Lbl"
                               Text="Import"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#4BA3C3"
                               VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4BA3C3"/>
                                <Setter TargetName="Icon" Property="Fill" Value="White"/>
                                <Setter TargetName="Lbl" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#175676"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#175676"/>
                                <Setter TargetName="Icon" Property="Fill" Value="White"/>
                                <Setter TargetName="Lbl" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
        <StackPanel Margin="50" HorizontalAlignment="Center" x:Name="PuzzlesPanel" Visibility="Collapsed">
            <TextBlock Text="Puzzles"
               x:Name="PuzzlesHeader"
               FontSize="68"
               FontWeight="Bold"
               Foreground="White"
               Margin="0,0,0,15"/>

            <!-- Back Button -->
            <Button x:Name="BackButton"
            Click="BackButton_Click"
            HorizontalAlignment="Left"
            Margin="0,0,0,15"
            Width="100"
            Height="35"
            Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                        Background="Transparent"
                        BorderBrush="White"
                        BorderThickness="2"
                        CornerRadius="6">
                            <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <TextBlock x:Name="Lbl"
                                   Text="← Back"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                                <Setter TargetName="Lbl" Property="Foreground" Value="#175676"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4BA3C3"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4BA3C3"/>
                                <Setter TargetName="Lbl" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Two Pane Layout -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Pane: Puzzle List -->
                <Border Grid.Column="0"
                Background="White"
                CornerRadius="8"
                Padding="0">
                    <ListView x:Name="PuzzleListView"
                      BorderThickness="0"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"                             
                              MaxHeight="600"
                      Background="Transparent"
                      SelectionChanged="PuzzleListView_SelectionChanged"
                      MouseDoubleClick="PuzzleListView_DoubleClick">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="33"/>
                                <Setter Property="Foreground" Value="#175676"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                            <Style TargetType="ListViewItem">
                                <Setter Property="FontSize" Value="24"/>
                            </Style>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Puzzle"
                                        Width="150"
                                        DisplayMemberBinding="{Binding Label}"/>
                                <GridViewColumn Header="Solved"
                                        Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSolved, Mode=OneWay}"
                                              IsEnabled="False"
                                              HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <!-- Right Pane: Preview -->
                <Border Grid.Column="2"
                Background="White"
                CornerRadius="8"
                Padding="15">
                    <StackPanel>
                        <TextBlock x:Name="PreviewLabel"
                           Text="Select a puzzle to preview"
                           FontSize="34"
                           Foreground="#175676"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"
                           HorizontalAlignment="Center"/>
                        <local:SudokuGrid
                    x:Name="PreviewGrid"
                    CellWidth="60"
                    CellHeight="60"
                    CellBackground="White"
                    TextColor="Black"
                    OuterBorderThickness="2"
                    OuterBorderColor="Black"
                    BoxBorderThickness="1.5"
                    BoxBorderColor="Black"
                    InnerBorderThickness="0.5"
                    InnerBorderColor="Gray"
                    SolvedFontSize="14"
                    CandidateFontSize="6"
                    MatchHighlightColor="#FFDC64"
                    MatchCandidateHighlightColor="#C8ECEC"
                    MatchContextHighlightColor="#FFFDE0"
                    VisibilityHighlightColor="#E0F6FA"
                    VisibilitySelectedColor="#64C8DC"
                    ErrorColor="#FF5050"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>

    </Grid>
</Window>
