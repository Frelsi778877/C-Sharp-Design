<Window x:Class="SudokuUnlimited.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SudokuUnlimited"
        mc:Ignorable="d"
        Title="MainWindow" WindowStyle="None" ResizeMode="NoResize" WindowState="Maximized">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#175676" Offset="0.0"/>
            <GradientStop Color="#4BA3C3" Offset="0.5"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock 
            Grid.Row="0"
            Text="Sudoku Unlimited"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               FontSize="104"
               Foreground="#CCE6F4"
               FontWeight="Bold"
               Margin="0,200,0,200"/>

        <TextBlock Grid.Row="1" Text="Play"
       HorizontalAlignment="Center"
       VerticalAlignment="Top"
       FontSize="74"
       FontWeight="Bold"
       Margin="0,50,0,10"
                   MouseLeftButtonUp="Show_GameWindow">

            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <!-- Default color -->
                    <Setter Property="Foreground" Value="#CCE6F4"/>

                    <Setter Property="Cursor" Value="Hand"/>

                    <Style.Triggers>
                        <!-- Hover color -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#BA324F"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>

        </TextBlock>

        <TextBlock Grid.Row="2"
           Focusable="True"
           Text="Exit"
           HorizontalAlignment="Center"
           VerticalAlignment="Top"
           FontSize="74"
           FontWeight="Bold"
           Margin="0,0,0,0"
            MouseLeftButtonUp="Exit_Click"
                   >

            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <!-- Default color -->
                    <Setter Property="Foreground" Value="#CCE6F4"/>

                    <Setter Property="Cursor" Value="Hand"/>

                    <Style.Triggers>
                        <!-- Hover color -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#BA324F"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        
        </TextBlock>

    </Grid>
</Window>
